// Unit tests for Lattish — run via: npm test
// Requires DOM (jsdom). Tests h(), Fragment, useState, useRef, createRoot.
// h() returns vnodes; DOM is produced by createRoot / patchRoot.

import { h, Fragment, useState, useRef, createRoot } from "../src/Lattish.tish"

fn assert(cond, msg) {
  if (!cond) {
    throw "Assertion failed: " + msg
  }
}

fn mountInDiv(vnodeFn) {
  let c = document.createElement("div")
  createRoot(c).render(vnodeFn)
  return c
}

fn testH() {
  let c1 = mountInDiv(() => h("div", { class: "foo" }, ["hello"]))
  let el = c1.firstChild
  assert(el && el.tagName === "DIV", "h(div) tagName")
  assert(el.className === "foo", "h(div) class")
  assert(el.textContent === "hello", "h(div) textContent")

  let c2 = mountInDiv(() => h("input", { type: "text", value: "x" }, []))
  let input = c2.firstChild
  assert(input && input.value === "x", "h(input) value")

  let c3 = mountInDiv(() => h("button", { disabled: true }, []))
  let disabled = c3.firstChild
  assert(disabled && disabled.disabled === true, "h(button) disabled")
}

fn testFragment() {
  let c = mountInDiv(() => h(Fragment, null, [
    h("span", null, ["a"]),
    "b",
    h("span", null, ["c"])
  ]))
  assert(c.childNodes.length === 3, "Fragment has 3 children")
  assert(c.childNodes[0].tagName === "SPAN", "Fragment child 0 span")
  assert(c.childNodes[1].textContent === "b", "Fragment child 1 text")
  assert(c.childNodes[2].tagName === "SPAN", "Fragment child 2 span")
}

fn testUseState() {
  let [v, setV] = useState(42)
  assert(v === 42, "useState initial value")
  let ctx = { container: document.createElement("div") }
  let root = createRoot(ctx.container)
  root.render(() => {
    let [x, setX] = useState(0)
    return h("div", null, [String(x)])
  })
  assert(ctx.container.textContent === "0", "useState initial render")
}

fn testUseRef() {
  let ctx = { container: document.createElement("div") }
  let root = createRoot(ctx.container)
  let refVal = { current: null }
  root.render(() => {
    let ref = useRef(null)
    refVal.current = ref
    return h("div", { ref: ref }, ["x"])
  })
  assert(refVal.current.current !== null, "useRef bound to element")
  assert(refVal.current.current.tagName === "DIV", "useRef element is div")
}

// Regression: useRef must grow refSlots with i >= length (same as useMemo), not i < length
// (wrong comparison caused infinite push / RangeError when useState ran before useRef).
fn testUseRefAfterUseState() {
  let ctx = { container: document.createElement("div") }
  let root = createRoot(ctx.container)
  root.render(() => {
    let [n, setN] = useState(0)
    let r = useRef(null)
    return h("div", { ref: r }, [String(n)])
  })
  assert(ctx.container.firstChild !== null, "useRef after useState renders")
}

fn testStyleObject() {
  let c = mountInDiv(() => h("span", { style: { display: "none", marginTop: "2px" } }, ["x"]))
  let el = c.firstChild
  assert(el && el.style.display === "none", "style.display none")
  assert(el.style.marginTop === "2px", "style marginTop")
}

fn main() {
  testH()
  testFragment()
  testUseState()
  testUseRef()
  testUseRefAfterUseState()
  testStyleObject()
  console.log("Lattish tests passed")
}

main()
