// Fragment — group children without a wrapper element
// Docs: https://lattish.dev/docs/api/exports
// Compile: tish compile --target js examples/08-fragment.tish -o dist/08-fragment

import { createRoot } from 'lattish'

fn App() {
  return <>
    <p>First paragraph</p>
    <p>{"Second paragraph"}</p>
  </>
}

createRoot(document.getElementById("root")).render(App)
