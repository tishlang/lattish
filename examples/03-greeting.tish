// Component pattern — child components with props
// Docs: https://lattish.dev/docs/getting-started/usage
// Compile: tish compile --target js examples/03-greeting.tish -o dist/03-greeting

import { createRoot } from 'lattish'

fn Greeting(props) {
  let name = props.name ?? "World"
  return <p>{"Hello, " + name + "!"}</p>
}

fn App() {
  return <div>
    <Greeting name="Lattish" />
  </div>
}

createRoot(document.getElementById("root")).render(App)
