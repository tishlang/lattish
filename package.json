{
  "name": "lattish",
  "version": "0.1.0",
  "description": "Lattish runtime — hooks + DOM for Tish JSX",
  "license": "PIF",
  "repository": {
    "type": "git",
    "url": "https://github.com/tishlang/lattish.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "tish": {
    "module": "./src/Lattish.tish"
  },
  "main": "./dist/Lattish.js",
  "module": "./dist/Lattish.js",
  "exports": {
    ".": {
      "tish": "./src/Lattish.tish",
      "import": "./dist/Lattish.js",
      "require": "./dist/Lattish.js",
      "default": "./dist/Lattish.js"
    }
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "examples/"
  ],
  "scripts": {
    "build": "tish compile --target js src/Lattish.tish -o dist/Lattish.js && node -e \"require('fs').appendFileSync('dist/Lattish.js', '\\nexport { Fragment, h, text, useLayoutEffect, useEffect, unstable_batchedUpdates, useState, useMemo, useRef, createRoot };\\n')\"",
    "tishversion": "tish -V",
    "test": "node test/run-tests.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tishlang/tish": "^1.0.21",
    "jsdom": "^25.0.0",
    "semantic-release": "^25.0.3"
  }
}
