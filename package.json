{
  "name": "lattish",
  "version": "0.1.0",
  "description": "Lattish runtime — hooks + DOM for Tish JSX",
  "license": "PIF",
  "repository": {
    "type": "git",
    "url": "https://github.com/tishlang/lattish.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "tish": {
    "module": "./src/Lattish.tish"
  },
  "main": "./src/Lattish.tish",
  "files": [
    "src/",
    "README.md",
    "examples/"
  ],
  "scripts": {
    "build": "tish compile --target js src/Lattish.tish -o dist/Lattish.js",
    "tishversion": "tish -V",
    "test": "node test/run-tests.mjs",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tishlang/tish": "^1.0.21",
    "jsdom": "^25.0.0",
    "semantic-release": "^25.0.3"
  }
}
